{
  "name": "phantomchat-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier . --write",
    "lint": "eslint .",
    "preview": "vite preview",
    "prettylint": "eslint . --fix && prettier . --write",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged && npm run typecheck"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tolgee/react": "^6.6.0",
    "clsx": "^2.1.1",
    "emoji-picker-react": "^4.18.0",
    "i18next": "^25.10.9",
    "libsodium-wrappers": "^0.8.2",
    "lucide-react": "^1.7.0",
    "luxon": "^3.7.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.2",
    "react-router-dom": "^7.13.2",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
